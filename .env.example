OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# VLM_PROVIDER=openai uses OpenAI Responses API.
# VLM_PROVIDER=local_vllm uses a local OpenAI-compatible vLLM server.
# VLM_PROVIDER=ollama uses local Ollama with no LLM API key.
VLM_PROVIDER=openai
LOCAL_VLLM_BASE_URL=http://127.0.0.1:8001/v1
LOCAL_VLLM_API_KEY=local-token
LOCAL_VLLM_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
LOCAL_VLLM_TEMPERATURE=0

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5vl
OLLAMA_TEMPERATURE=0

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

API_DATA_DIR=
API_ENABLE_VLM=true
API_LOW_CONFIDENCE_THRESHOLD=0.62

NEXT_PUBLIC_API_BASE=http://localhost:8000
